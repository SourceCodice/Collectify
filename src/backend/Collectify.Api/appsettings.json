{
  "LocalData": {
    "RootPath": "%LOCALAPPDATA%\\Collectify",
    "DataFileName": "collectify-data.json",
    "ImagesDirectoryName": "assets\\images",
    "BackupsDirectoryName": "backups",
    "SettingsFileName": "settings.json"
  },
  "ExternalMetadata": {
    "Retry": {
      "MaxRetries": 2,
      "InitialDelayMilliseconds": 500
    },
    "TMDb": {
      "BaseUrl": "https://api.themoviedb.org/3",
      "ApiKey": "",
      "AccessToken": "",
      "RequestsPerSecond": 4
    },
    "RAWG": {
      "BaseUrl": "https://api.rawg.io/api",
      "ApiKey": "",
      "RequestsPerSecond": 4
    },
    "Discogs": {
      "BaseUrl": "https://api.discogs.com",
      "ApiKey": "",
      "ApiSecret": "",
      "RequestsPerSecond": 2
    },
    "ProviderResolver": {
      "Categories": {
        "Cinema": {
          "Aliases": ["Movies", "Movie", "Film", "Blu-ray", "Blu ray", "Bluray", "DVD", "4K UHD", "UHD"],
          "Providers": [
            {
              "ProviderId": "tmdb",
              "DisplayName": "TMDb",
              "Kind": "movie",
              "Role": "primary",
              "IsEnabled": true,
              "Notes": "Provider principale per film e cinema."
            },
            {
              "ProviderId": "imdb",
              "DisplayName": "IMDb",
              "Kind": "movie",
              "Role": "future",
              "IsEnabled": false,
              "Notes": "Provider futuro/opzionale, non incluso nell'MVP."
            }
          ]
        },
        "Videogiochi": {
          "Aliases": ["Videogames", "Games", "Game"],
          "Providers": [
            {
              "ProviderId": "rawg",
              "DisplayName": "RAWG",
              "Kind": "game",
              "Role": "primary",
              "IsEnabled": true,
              "Notes": "Provider principale per videogiochi."
            }
          ]
        },
        "Musica": {
          "Aliases": ["Music", "Albums", "Album", "Vinile", "CD"],
          "Providers": [
            {
              "ProviderId": "discogs",
              "DisplayName": "Discogs",
              "Kind": "album",
              "Role": "primary",
              "IsEnabled": true,
              "Notes": "Provider principale per album e musica."
            }
          ]
        },
        "Libri": {
          "Aliases": ["Books", "Book"],
          "Providers": [
            {
              "ProviderId": "books",
              "DisplayName": "Provider libri",
              "Kind": "book",
              "Role": "future",
              "IsEnabled": false,
              "Notes": "Predisposizione futura per metadati libri."
            }
          ]
        },
        "Auto": {
          "Aliases": ["Cars"],
          "ManualEntryOnly": true
        },
        "Piante": {
          "Aliases": ["Plants"],
          "ManualEntryOnly": true
        },
        "Arredo": {
          "Aliases": ["Furniture", "Mobili"],
          "ManualEntryOnly": true
        }
      }
    }
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:5173",
      "http://127.0.0.1:5173"
    ]
  }
}
