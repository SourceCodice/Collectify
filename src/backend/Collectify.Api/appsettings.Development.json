{
  "Development": {
    "OpenFrontendOnStart": true,
    "AutoStartFrontend": true,
    "FrontendLaunchMode": "Electron",
    "FrontendUrl": "http://127.0.0.1:5173",
    "FrontendProjectPath": "..\\..\\frontend\\collectify-desktop",
    "FrontendStartArguments": "run dev",
    "RendererStartArguments": "run dev:renderer",
    "ElectronStartArguments": "run electron:open",
    "FrontendStartupTimeoutSeconds": 45
  },
  "LocalData": {
    "RootPath": "..\\..\\..\\data\\dev",
    "DataFileName": "collectify-data.json",
    "ImagesDirectoryName": "assets\\images",
    "BackupsDirectoryName": "backups",
    "SettingsFileName": "settings.json"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}
